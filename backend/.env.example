# Copy this to .env and update values for local development
PORT=5000
# Example: postgres://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgres://postgres:12345@localhost:5432/civicfix_db
JWT_SECRET=your_jwt_secret
# ml-service (see ml-service/) — Python microservice serving photo classification
ML_SERVICE_URL=http://localhost:8000
# Optional: localtunnel subdomain for exposing server
# TUNNEL_SUBDOMAIN=your-unique-subdomain
